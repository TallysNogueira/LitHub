<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    
    <!-- Cor de fundo do campo -->
    <solid android:color="#E4E9F0" />
    
    <!-- Raio dos cantos arredondados (ajuste o valor para mais ou menos arredondado) -->
    <corners android:radius="20dp" />
    
    <!-- Borda -->
    <stroke
        android:width="3dp"
        android:color="#DC143C" />
    
    <!-- Espaçamento interno (Opcional) -->
    <padding
        android:left="10dp"
        android:right="10dp"
        android:top="5dp"
        android:bottom="5dp" />
</shape>
